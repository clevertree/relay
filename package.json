{
  "name": "relay-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "build:rust": "cargo build",
    "test:rust": "cargo test",
    "lint:rust": "cargo clippy -- -D warnings",
    "format:rust": "cargo fmt",
    "dev:host": "cargo run -p relay-cli -- host start --port 8080 --root ./host",
    "web:dev": "pnpm --filter ./apps/web dev",
    "web:build": "pnpm --filter ./apps/web build",
    "web:export": "pnpm --filter ./apps/web export",
    "web:export:to-host": "node scripts/copy-web-to-host.mjs"
  },
  "devDependencies": {
    "turbo": "^2.0.12"
  }
}
