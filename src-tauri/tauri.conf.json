{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Relay Desktop",
  "version": "0.1.0",
  "identifier": "com.relay.desktop",
  "build": {
    "frontendDist": "../host/static",
    "devUrl": "http://localhost:13337",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Relay",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
    ,
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
