{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Relay Desktop",
  "version": "0.1.0",
  "identifier": "com.relay.desktop",
  "build": {
    "distDir": "../host/static",
    "devPath": "http://localhost:3000",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "tauri": {
    "windows": [
      {
        "title": "Relay",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "allowlist": {
      "all": true
    }
  }
}
