{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "build/**",
        "target/**",
        "apps/web/.next/**",
        "apps/web/out/**",
        "crates/relay-wasm/pkg/**",
        "public/**"
      ]
    },
    "dev": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {},
    "format": {}
  }
}
